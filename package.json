{
  "name": "transfers-app",
  "version": "2.1.0",
  "description": "Real-time collaborative table + Audio Control + Relay Manager",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2": "pm2 start server.js --name transfers-app",
    "pm2-stop": "pm2 stop transfers-app",
    "logs": "pm2 logs transfers-app",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:security": "jest tests/security.test.js",
    "test:performance": "jest tests/performance.test.js",
    "test:debug": "jest --verbose --no-coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint . --ext .js 2>/dev/null || echo 'ESLint not installed'",
    "audit": "npm audit",
    "test:all": "bash run-tests.sh"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "mysql2": "^3.6.5",
    "node-cache": "^5.1.2",
    "socket.io": "^4.5.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "socket.io-client": "^4.5.4"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}